{l:"thermae",s:"therm",g:"f",d:"a",k:7,de:"Thermen",dg:"f",w:0,dp:"Thermen",pt:1},
{l:"toga",s:"tog",g:"f",d:"a",k:7,de:"Toga",dg:"f",w:0,dp:"Togen"},
{l:"vestis",s:"vest",g:"f",d:"kons",k:7,de:"Kleidung",dg:"f",w:0,dp:"Kleider"},
{l:"hōra",s:"hōr",g:"f",d:"a",k:7,de:"Stunde",dg:"f",w:0,dp:"Stunden"},
{l:"silentium",s:"silenti",g:"n",d:"o",k:7,de:"Stille",dg:"f",w:0,dp:"Stillen"},
{l:"aqua",s:"aqu",g:"f",d:"a",k:7,de:"Wasser",dg:"n",w:0,dp:"Wasser"},

{l:"vōx",s:"vōc",g:"f",d:"kons",k:8,de:"Stimme",dg:"f",w:0,dp:"Stimmen"},
{l:"patrōnus",s:"patrōn",g:"m",d:"o",k:8,de:"Schutzherr",dg:"m",w:0,dp:"Schutzherren"},
{l:"sermō",s:"sermōn",g:"m",d:"kons",k:8,de:"Gespräch",dg:"n",w:0,dp:"Gespräche"},
{l:"cōnsilium",s:"cōnsili",g:"n",d:"o",k:8,de:"Rat",dg:"m",w:0,dp:"Räte"},
{l:"aestās",s:"aestāt",g:"f",d:"kons",k:8,de:"Sommer",dg:"m",w:0,dp:"Sommer"},
{l:"secūtor",s:"secūtōr",g:"m",d:"kons",k:8,de:"Verfolger",dg:"m",w:0,dp:"Verfolger"},
{l:"porta",s:"port",g:"f",d:"a",k:8,de:"Tor",dg:"n",w:0,dp:"Tore"},
{l:"rētiārius",s:"rētiāri",g:"m",d:"o",k:8,de:"Netzkämpfer",dg:"m",w:0,dp:"Netzkämpfer"},
{l:"arēna",s:"arēn",g:"f",d:"a",k:8,de:"Arena",dg:"f",w:0,dp:"Arenen"},
{l:"gladiātor",s:"gladiātōr",g:"m",d:"kons",k:8,de:"Gladiator",dg:"m",w:0,dp:"Gladiatoren"}
];

/* ---------------- Deklinationstabellen ---------------- */
const ENDINGS = {
  a:      {sg:{gen:"ae",dat:"ae",akk:"am",abl:"ā"},   pl:{nom:"ae", gen:"ārum",dat:"īs",  akk:"ās", abl:"īs"}},
  o_m:    {sg:{gen:"ī", dat:"ō", akk:"um",abl:"ō"},   pl:{nom:"ī", gen:"ōrum",dat:"īs",  akk:"ōs", abl:"īs"}},
  o_n:    {sg:{gen:"ī", dat:"ō", akk:null,abl:"ō"},   pl:{nom:"a", gen:"ōrum",dat:"īs",  akk:null, abl:"īs"}},
  kons:   {sg:{gen:"is",dat:"ī", akk:"em",abl:"e"},   pl:{nom:"ēs",gen:"um",  dat:"ibus",akk:"ēs", abl:"ibus"}},
  kons_n: {sg:{gen:"is",dat:"ī", akk:null,abl:"e"},   pl:{nom:"a", gen:"um",  dat:"ibus",akk:null, abl:"ibus"}}
};
const DECL_INFO = {
  a:      {name:"a-Deklination", tip:"fast immer feminin. Erkennbar am Nominativ auf -a. Genitiv/Dativ Sg. auf -ae, Akkusativ Sg. auf -am, Ablativ Sg. auf -ā (langes a!)."},
  o_m:    {name:"o-Deklination (maskulin)", tip:"Nominativ meist auf -us (manchmal -er, z. B. puer, vir, magister). Genitiv Sg. auf -ī, Akkusativ Sg. auf -um, Ablativ Sg. auf -ō."},
  o_n:    {name:"o-Deklination (neutrum)", tip:"Nominativ auf -um. Akkusativ ist immer identisch mit dem Nominativ. Nominativ/Akkusativ Plural enden auf -a."},
  kons:   {name:"konsonantische Deklination", tip:"Nominativ Sg. ist unregelmäßig – am sichersten erkennst du diese Deklination am Genitiv Sg. auf -is. Akkusativ Sg. auf -em, Ablativ Sg. auf -e."},
  kons_n: {name:"konsonantische Deklination (neutrum)", tip:"Genitiv Sg. auf -is. Akkusativ ist immer identisch mit dem Nominativ. Nominativ/Akkusativ Plural enden auf -a."}
};
function declKey(n){ if(n.d==="a") return "a"; if(n.d==="o") return n.g==="n"?"o_n":"o_m"; return n.g==="n"?"kons_n":"kons"; }

function paradigm(n){
  const key = declKey(n), t = ENDINGS[key], f = {};
  f.sg_nom = n.l;
  f.pl_nom = n.s + t.pl.nom;
  ["gen","dat","akk","abl"].forEach(c=>{
    f["sg_"+c] = t.sg[c]===null ? f.sg_nom : n.s + t.sg[c];
    f["pl_"+c] = t.pl[c]===null ? f.pl_nom : n.s + t.pl[c];
  });
  return f;
}

const CASUS_LABEL = {nom:"Nominativ",gen:"Genitiv",dat:"Dativ",akk:"Akkusativ",abl:"Ablativ"};
const CASUS_Q = {nom:"Wer/Was?",gen:"Wessen?",dat:"Wem?",akk:"Wen/Was?",abl:"Womit/Wodurch/Wo/Wovon?"};
const NUM_LABEL = {sg:"Singular",pl:"Plural"};
const GEN_LABEL = {m:"maskulin",f:"feminin",n:"neutrum"};

/* ---------------- Kasusfragen (wie Übung "Ablativverwendungen") ---------------- */
const KASUS_QUESTIONS = [
  {kasus:"nom", frage:"Wer? / Was? (Subjekt)"},
  {kasus:"gen", frage:"Wessen?"},
  {kasus:"dat", frage:"Wem?"},
  {kasus:"akk", frage:"Wen? / Was?"},
  {kasus:"abl", frage:"Wann? (Ablativus temporis)"},
  {kasus:"abl", frage:"Womit? / Wodurch? (Ablativus instrumentalis)"},
  {kasus:"abl", frage:"Mit wem? (Ablativus sociativus)"},
  {kasus:"abl", frage:"Wo? (Ablativus loci)"},
  {kasus:"abl", frage:"Woher? (Ablativus der Herkunft)"}
];

/* ---------------- Lückensatz ---------------- */
// word = Nominativ Singular (Schlüssel in VOCAB), kasus/num = gesuchte Form, tmpl mit "___" als Lücke
const LUECKEN = [
  {word:"puer",       kasus:"akk", num:"sg", tmpl:"Puella ___ videt.",              trans:"Das Mädchen sieht den Jungen."},
