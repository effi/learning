{l:"homō",s:"homin",g:"m",d:"kons",k:5,de:"Mensch",dg:"m",w:1,dp:"Menschen"},
{l:"amīcus",s:"amīc",g:"m",d:"o",k:5,de:"Freund",dg:"m",w:0,dp:"Freunde"},
{l:"amīca",s:"amīc",g:"f",d:"a",k:5,de:"Freundin",dg:"f",w:0,dp:"Freundinnen"},
{l:"dōnum",s:"dōn",g:"n",d:"o",k:5,de:"Geschenk",dg:"n",w:0,dp:"Geschenke"},
{l:"fūr",s:"fūr",g:"m",d:"kons",k:5,de:"Dieb",dg:"m",w:0,dp:"Diebe"},

{l:"mors",s:"mort",g:"f",d:"kons",k:6,de:"Tod",dg:"m",w:0,dp:"Tode"},
{l:"spectātor",s:"spectātōr",g:"m",d:"kons",k:6,de:"Zuschauer",dg:"m",w:0,dp:"Zuschauer"},
