<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Latein">
<title>Latein Deklinationen</title>
<style>
  :root{
    --blue:#0a6ee6; --blue-d:#0655b8;
    --green:#1fae5c; --green-bg:#e7faf0;
    --red:#e0453c; --red-bg:#fdeceb;
    --bg:#f2f3f7; --card:#ffffff; --ink:#1c2130; --sub:#68708a;
    --line:#e6e8ef; --radius:16px;
  }
  *{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
  html,body{height:100%;}
  body{
    margin:0; background:var(--bg); color:var(--ink);
    font-family:-apple-system,BlinkMacSystemFont,"SF Pro Text",Segoe UI,Roboto,sans-serif;
    padding-top:env(safe-area-inset-top); padding-bottom:env(safe-area-inset-bottom);
    -webkit-user-select:none; user-select:none;
  }
  header{
    position:sticky; top:0; z-index:20; background:rgba(242,243,247,.92); backdrop-filter:blur(10px);
    padding:14px 16px 10px; border-bottom:1px solid var(--line);
  }
  h1{font-size:19px; margin:0 0 10px; font-weight:700; letter-spacing:-.2px;}
  .tabs{display:flex; gap:6px; background:#e4e6ee; border-radius:12px; padding:3px; overflow-x:auto; -webkit-overflow-scrolling:touch; scrollbar-width:none;}
  .tabs::-webkit-scrollbar{display:none;}
  .tab{flex:0 0 auto; text-align:center; padding:8px 12px; border-radius:9px; font-size:13px; font-weight:600; color:var(--sub); white-space:nowrap;}
  .tab.active{background:#fff; color:var(--ink); box-shadow:0 1px 3px rgba(0,0,0,.12);}
  .settingsBtn{position:absolute; right:16px; top:14px; font-size:20px; color:var(--sub); background:none; border:none; padding:4px;}
  main{padding:16px; max-width:520px; margin:0 auto; padding-bottom:60px;}
  .card{background:var(--card); border-radius:var(--radius); padding:18px; box-shadow:0 1px 2px rgba(20,20,40,.05); margin-bottom:14px;}
  .stats{display:flex; gap:10px; font-size:12px; color:var(--sub); margin-bottom:10px;}
  .stats b{color:var(--ink);}
  .chip{padding:3px 9px; border-radius:20px; background:#eef0f6;}
  .prompt-label{font-size:12px; color:var(--sub); font-weight:600; text-transform:uppercase; letter-spacing:.5px; margin-bottom:6px;}
  .latinWord{font-size:34px; font-weight:700; text-align:center; margin:6px 0 4px; color:var(--blue-d); letter-spacing:-.5px;}
  .meaning{text-align:center; color:var(--sub); font-size:14px; margin-bottom:16px;}
  .lektTag{text-align:center; font-size:11px; color:var(--sub); margin-bottom:14px;}
  .grp{margin-bottom:14px;}
  .grp-label{font-size:12px; color:var(--sub); font-weight:600; margin-bottom:6px;}
  .btnrow{display:flex; flex-wrap:wrap; gap:8px;}
  .opt{
    flex:1 1 auto; min-width:64px; padding:11px 6px; text-align:center; border-radius:12px;
    background:#eef0f6; border:2px solid transparent; font-size:14px; font-weight:600; color:var(--ink);
  }
  .opt.sel{border-color:var(--blue); background:#e5f0fe; color:var(--blue-d);}
  .opt.correct{background:var(--green-bg); border-color:var(--green); color:var(--green);}
  .opt.wrong{background:var(--red-bg); border-color:var(--red); color:var(--red);}
  .mcOpt{
    width:100%; text-align:center; padding:15px; border-radius:12px; background:#eef0f6;
    font-size:20px; font-weight:700; border:2px solid transparent; margin-bottom:9px; color:var(--ink);
  }
  .mcOpt.correct{background:var(--green-bg); border-color:var(--green); color:var(--green);}
  .mcOpt.wrong{background:var(--red-bg); border-color:var(--red); color:var(--red);}
  .askrow{display:flex; justify-content:center; gap:8px; margin-bottom:16px;}
  .askchip{padding:6px 14px; border-radius:20px; background:#e5f0fe; color:var(--blue-d); font-weight:700; font-size:13px;}
  .primary{
    display:block; width:100%; padding:15px; border-radius:14px; background:var(--blue); color:#fff;
    font-size:16px; font-weight:700; border:none; text-align:center; margin-top:6px;
  }
  .primary:disabled{background:#c7cede;}
  .secondary:disabled{opacity:.4;}
  .secondary{
    display:block; width:100%; padding:13px; border-radius:14px; background:#eef0f6; color:var(--ink);
    font-size:15px; font-weight:600; border:none; text-align:center; margin-top:8px;
  }
  .feedback{border-radius:14px; padding:14px 16px; margin-top:14px; font-size:14px; line-height:1.5;}
  .feedback.ok{background:var(--green-bg); color:#0f7a3c;}
  .feedback.bad{background:var(--red-bg); color:#a8271f;}
  .feedback b{display:block; margin-bottom:4px; font-size:15px;}
  .feedback .why{margin-top:8px; color:var(--ink); opacity:.85;}
  .feedback .trans{margin-top:8px; font-style:italic; color:var(--ink); opacity:.75; font-size:13px;}
  /* settings drawer */
  .overlay{position:fixed; inset:0; background:rgba(20,22,35,.4); z-index:40; display:none;}
  .overlay.show{display:block;}
  .drawer{
    position:fixed; right:0; top:0; bottom:0; width:86%; max-width:360px; background:#fff; z-index:50;
    transform:translateX(100%); transition:transform .25s ease; overflow-y:auto;
    padding:calc(env(safe-area-inset-top) + 16px) 18px 24px;
  }
  .drawer.show{transform:translateX(0);}
  .drawer h2{font-size:16px; margin:18px 0 8px;}
  .drawer h2:first-child{margin-top:0;}
  .rowline{display:flex; align-items:center; justify-content:space-between; padding:9px 0; border-bottom:1px solid var(--line); font-size:14px;}
  .sw{position:relative; width:44px; height:26px; border-radius:16px; background:#d8dae4;}
  .sw.on{background:var(--green);}
  .sw::after{content:''; position:absolute; top:2px; left:2px; width:22px; height:22px; border-radius:50%; background:#fff; transition:.15s; box-shadow:0 1px 3px rgba(0,0,0,.3);}
  .sw.on::after{left:20px;}
  .drawer .closeX{position:absolute; top:calc(env(safe-area-inset-top) + 14px); right:14px; font-size:22px; color:var(--sub); background:none; border:none;}
  .miniNote{font-size:12px; color:var(--sub); margin-top:4px; line-height:1.4;}
  /* reference tables */
  .refTable{width:100%; border-collapse:collapse; font-size:13px; margin-bottom:6px;}
  .refTable th,.refTable td{padding:6px 4px; text-align:center; border-bottom:1px solid var(--line);}
  .refTable th{color:var(--sub); font-weight:600; font-size:11px; text-transform:uppercase;}
  .refTable td:first-child{text-align:left; color:var(--sub); font-weight:600;}
  .refHead{font-weight:700; font-size:14px; margin:16px 0 6px; color:var(--blue-d);}
  .refHead:first-child{margin-top:0;}
  .empty{text-align:center; color:var(--sub); padding:30px 10px; font-size:14px; line-height:1.6;}
  /* Layover: vollständige Deklination */
  .modalWrap{position:fixed; inset:0; z-index:60; display:none; align-items:center; justify-content:center; padding:22px;}
  .modalWrap.show{display:flex;}
  .modalWrap::before{content:''; position:absolute; inset:0; background:rgba(20,22,35,.45);}
  .modalCard{position:relative; background:#fff; border-radius:18px; padding:22px 20px 18px; max-width:420px; width:100%; max-height:82vh; overflow-y:auto;}
  .modalClose{position:absolute; top:10px; right:12px; font-size:20px; color:var(--sub); background:none; border:none; padding:6px;}
</style>
</head>
<body>

<header>
  <h1>Latein · Deklinationen</h1>
  <button class="settingsBtn" onclick="openDrawer()">⚙︎</button>
  <div class="tabs">
    <div class="tab active" data-tab="bestimmen" onclick="switchTab('bestimmen')">Bestimmen</div>
    <div class="tab" data-tab="formen" onclick="switchTab('formen')">Formen bilden</div>
    <div class="tab" data-tab="kasusfragen" onclick="switchTab('kasusfragen')">Kasusfragen</div>
    <div class="tab" data-tab="genitiv" onclick="switchTab('genitiv')">Genitiv-Sprint</div>
    <div class="tab" data-tab="vokabeln" onclick="switchTab('vokabeln')">Vokabeln</div>
    <div class="tab" data-tab="luecken" onclick="switchTab('luecken')">Lückensatz</div>
    <div class="tab" data-tab="tabellen" onclick="switchTab('tabellen')">Tabellen</div>
  </div>
</header>

<main id="main"></main>

<div class="overlay" id="overlay" onclick="closeDrawer()"></div>
<div class="drawer" id="drawer">
  <button class="closeX" onclick="closeDrawer()">✕</button>

  <h2>Lektionen</h2>
  <div id="lektList"></div>

  <h2>Deklinationen</h2>
  <div id="deklList"></div>

  <h2>Kasus abfragen</h2>
  <div id="casusList"></div>
  <div class="miniNote">Dativ ist optional (in deinen Übungen bisher nicht im Fokus).</div>

  <h2>Im Quiz zusätzlich abfragen</h2>
  <div class="rowline">Deklination (a/o/kons) erraten<div class="sw" id="swAskDekl" onclick="toggleAskDekl()"></div></div>
  <div class="miniNote">Deklinationstyp und Genus werden erst nach deiner Antwort angezeigt, nicht vorher.</div>

  <h2>Statistik</h2>
  <div class="rowline"><span>Richtig / Falsch</span><b id="statsLine">0 / 0</b></div>
  <button class="secondary" onclick="resetStats()">Statistik zurücksetzen</button>
</div>

<div class="modalWrap" id="paraModalWrap" onclick="if(event.target===this) closeParadigm()">
  <div class="modalCard" id="paraModalCard"></div>
</div>

<script>
/* ---------------- Vokabeldaten (Lektion 1-8) ---------------- */
// l=Nominativ Sg, s=Stamm, g=lat. Genus, d=Deklination(a/o/kons), k=Lektion,
// de=dt. Bedeutung, dg=dt. Genus, w=schwache dt. Deklination(1/0), dp=dt. Plural, pt=nur Plural(1/0)
