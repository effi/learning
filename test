function renderTabellen(){
  const examples = [
    {n:{l:"filia",s:"fili",g:"f",d:"a",de:"Tochter"}, key:"a"},
    {n:{l:"pater",s:"patr",g:"m",d:"kons",de:"Vater"}, key:"kons"},
    {n:{l:"servus",s:"serv",g:"m",d:"o",de:"Sklave"}, key:"o_m"},
    {n:{l:"verbum",s:"verb",g:"n",d:"o",de:"Wort"}, key:"o_n"}
  ];
  let html = `<div class="card">`;
  examples.forEach(ex=>{
    const f = paradigm(ex.n);
    html += `<div class="refHead">${DECL_INFO[ex.key].name} <span style="color:var(--sub);font-weight:400;">(${ex.n.l} — ${ex.n.de})</span></div>
    <table class="refTable">
      <tr><th></th><th>Singular</th><th>Plural</th></tr>
      <tr><td>Nom.</td><td>${f.sg_nom}</td><td>${f.pl_nom}</td></tr>
      <tr><td>Gen.</td><td>${f.sg_gen}</td><td>${f.pl_gen}</td></tr>
      <tr><td>Akk.</td><td>${f.sg_akk}</td><td>${f.pl_akk}</td></tr>
      <tr><td>Abl.</td><td>${f.sg_abl}</td><td>${f.pl_abl}</td></tr>
    </table>
    <div class="miniNote" style="margin-bottom:12px;">${DECL_INFO[ex.key].tip}</div>`;
  });
  html += `</div>`;
  return html;
}

