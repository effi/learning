function extraInfoHtml(n, kasus, num){
  const f = paradigm(n);
  const genSgLine = n.pt
    ? `<div>Genitiv Singular: <i>kommt bei "${n.l}" nur im Plural vor</i></div>`
    : `<div>Genitiv Singular: <b>${f.sg_gen}</b> <span style="opacity:.6;">(daran erkennst du oft die Deklination)</span></div>`;
  return `<div class="trans">
    <div>Grundform (Nom. Sg.): <b>${n.l}</b> — ${germanForm(n,"nom","sg")}</div>
    ${genSgLine}
    <div style="margin-top:6px;">Übersetzung hier (${CASUS_LABEL[kasus]} ${NUM_LABEL[num]}): ${germanForm(n,kasus,num)}</div>
  </div>`;
}

/* ---------------- Deutsche Übersetzungsform ---------------- */
function germanForm(n, kasus, numerus){
  let word = numerus==="pl" ? n.dp : n.de;
  let art;
  if(numerus==="sg"){
    if(n.dg==="f"){ art = {nom:"die",gen:"der",dat:"der",akk:"die",abl:"der"}; }
    else if(n.dg==="n"){
      art = {nom:"das",gen:"des",dat:"dem",akk:"das",abl:"dem"};
      if(kasus==="gen") word += "s";
    } else {
      art = {nom:"der",gen:"des",dat:"dem",akk:"den",abl:"dem"};
      if(n.w){ if(kasus!=="nom") word += "n"; }
      else { if(kasus==="gen") word += "s"; }
    }
  } else {
    art = {nom:"die",gen:"der",dat:"den",akk:"die",abl:"den"};
    if((kasus==="dat"||kasus==="abl") && !word.endsWith("n")) word += "n";
  }
  const prefix = kasus==="abl" ? "(von) " : "";
  return prefix + art[kasus] + " " + word;
}

/* ---------------- State ---------------- */
const DEFAULT_SETTINGS = {
  lekt:[1,2,3,4,5,6,7,8],
  dekl:["a","o","kons"],
  cas:["nom","gen","akk","abl"],
  askDekl:true
};
function loadSettings(){
  try{
    const raw = JSON.parse(localStorage.getItem("latein_settings"));
    if(!raw) return {...DEFAULT_SETTINGS};
    return {
      lekt: Array.isArray(raw.lekt) && raw.lekt.length ? raw.lekt : DEFAULT_SETTINGS.lekt,
      dekl: Array.isArray(raw.dekl) && raw.dekl.length ? raw.dekl : DEFAULT_SETTINGS.dekl,
      cas: Array.isArray(raw.cas) && raw.cas.length ? raw.cas : DEFAULT_SETTINGS.cas,
      askDekl: typeof raw.askDekl==="boolean" ? raw.askDekl : DEFAULT_SETTINGS.askDekl
    };
  }catch(e){ return {...DEFAULT_SETTINGS}; }
}
const savedSettings = loadSettings();
const state = {
  tab:"bestimmen",
  lekt: new Set(savedSettings.lekt),
  dekl: new Set(savedSettings.dekl),
  cas: new Set(savedSettings.cas),
  askDekl: savedSettings.askDekl,
  current: null,
  answered: false,
  selKasus:null, selNum:null, selGen:null, selDekl:null
};
function saveSettings(){
  localStorage.setItem("latein_settings", JSON.stringify({
    lekt:[...state.lekt], dekl:[...state.dekl], cas:[...state.cas], askDekl: state.askDekl
  }));
}
let stats = JSON.parse(localStorage.getItem("latein_stats")||'{"r":0,"f":0}');

function saveStats(){ localStorage.setItem("latein_stats", JSON.stringify(stats)); }
function resetStats(){ stats={r:0,f:0}; saveStats(); render(); }

function pool(){
  return VOCAB.filter(n => state.lekt.has(n.k) && state.dekl.has(n.d));
}
function activeCasesFor(n){
  let cs = [...state.cas];
  if(n.pt) cs = cs; // pluraletantum affects numerus, not casus
  return cs.length?cs:["nom"];
}
function pickNumerus(n){
  if(n.pt) return "pl";
  return Math.random()<0.5?"sg":"pl";
}
function randPick(arr){ return arr[Math.floor(Math.random()*arr.length)]; }

/* ---------------- Drawer ---------------- */
function openDrawer(){ buildDrawer(); document.getElementById("drawer").classList.add("show"); document.getElementById("overlay").classList.add("show"); }
function closeDrawer(){ document.getElementById("drawer").classList.remove("show"); document.getElementById("overlay").classList.remove("show"); render(); }

function buildDrawer(){
  const lektDiv = document.getElementById("lektList"); lektDiv.innerHTML="";
  for(let i=1;i<=8;i++){
    const on = state.lekt.has(i);
    lektDiv.innerHTML += `<div class="rowline">Lektion ${i}<div class="sw ${on?'on':''}" onclick="toggleLekt(${i})"></div></div>`;
  }
  const deklDiv = document.getElementById("deklList"); deklDiv.innerHTML="";
  const deklNames = {a:"a-Deklination", o:"o-Deklination", kons:"konsonantische Deklination"};
  Object.keys(deklNames).forEach(k=>{
    const on = state.dekl.has(k);
    deklDiv.innerHTML += `<div class="rowline">${deklNames[k]}<div class="sw ${on?'on':''}" onclick="toggleDekl('${k}')"></div></div>`;
  });
  const casDiv = document.getElementById("casusList"); casDiv.innerHTML="";
  ["nom","gen","akk","abl","dat"].forEach(c=>{
    const on = state.cas.has(c);
    casDiv.innerHTML += `<div class="rowline">${CASUS_LABEL[c]}<div class="sw ${on?'on':''}" onclick="toggleCas('${c}')"></div></div>`;
  });
  document.getElementById("statsLine").textContent = stats.r+" / "+stats.f;
  document.getElementById("swAskDekl").classList.toggle("on", state.askDekl);
}
function toggleLekt(i){ state.lekt.has(i)?state.lekt.delete(i):state.lekt.add(i); if(state.lekt.size===0) state.lekt.add(i); saveSettings(); buildDrawer(); }
function toggleDekl(k){ state.dekl.has(k)?state.dekl.delete(k):state.dekl.add(k); if(state.dekl.size===0) state.dekl.add(k); saveSettings(); buildDrawer(); }
function toggleCas(c){ state.cas.has(c)?state.cas.delete(c):state.cas.add(c); if(state.cas.size===0) state.cas.add(c); saveSettings(); buildDrawer(); }
function toggleAskDekl(){ state.askDekl = !state.askDekl; saveSettings(); buildDrawer(); }

/* ---------------- Tabs ---------------- */
function switchTab(t){
  state.tab = t;
  document.querySelectorAll(".tab").forEach(el=>el.classList.toggle("active", el.dataset.tab===t));
  newQuestion();
}

/* ---------------- Mode 1: Bestimmen ---------------- */
function newQuestion_bestimmen(){
  const p = pool();
  if(!p.length){ state.current=null; render(); return; }
  const n = randPick(p);
  const num = pickNumerus(n);
  const cs = activeCasesFor(n);
  const kasus = randPick(cs);
  const forms = paradigm(n);
  const form = forms[num+"_"+kasus];
  // Homograph-Check: alle passenden Kasus/Numerus-Kombis mit identischer Form (nur unter aktiven Filtern)
  const matches = [];
  ["sg","pl"].forEach(nu=>{
    if(n.pt && nu==="sg") return;
    cs.forEach(ka=>{ if(forms[nu+"_"+ka]===form) matches.push({num:nu,kasus:ka}); });
  });
  state.current = {n, num, kasus, form, matches};
  state.answered = false; state.selKasus=null; state.selNum=null; state.selGen=null; state.selDekl=null; state.selPairs=[];
  render();
}

function selectKasus(k){ if(state.answered) return; state.selKasus=k; render(); }
function selectNum(k){ if(state.answered) return; state.selNum=k; render(); }
function selectGen(k){ if(state.answered) return; state.selGen=k; render(); }
function selectDekl(k){ if(state.answered) return; state.selDekl=k; render(); }

function addPair(){
  if(state.answered || !state.selKasus || !state.selNum) return;
  const exists = state.selPairs.some(p=>p.kasus===state.selKasus && p.num===state.selNum);
  if(!exists) state.selPairs.push({kasus:state.selKasus, num:state.selNum});
  state.selKasus = null; state.selNum = null;
  render();
}
function removePair(idx){ if(state.answered) return; state.selPairs.splice(idx,1); render(); }

function submitBestimmen(){
  if(state.answered) return;
  const c = state.current;
  let pairs = [...state.selPairs];
  if(state.selKasus && state.selNum && !pairs.some(p=>p.kasus===state.selKasus && p.num===state.selNum)){
    pairs.push({kasus:state.selKasus, num:state.selNum});
  }
  if(!pairs.length || !state.selGen) return;
  if(state.askDekl && !state.selDekl) return;

  const matchKeys = c.matches.map(m=>m.kasus+"_"+m.num);
  const givenKeys = pairs.map(p=>p.kasus+"_"+p.num);
  const missing = c.matches.filter(m=>!givenKeys.includes(m.kasus+"_"+m.num));
  const extra = pairs.filter(p=>!matchKeys.includes(p.kasus+"_"+p.num));
  const genOk = state.selGen === c.n.g;
  const deklOk = state.askDekl ? (state.selDekl === c.n.d) : true;
  const ok = missing.length===0 && extra.length===0 && genOk && deklOk;

  state.finalPairs = pairs; state.finalMissing = missing; state.finalExtra = extra;
  state.answered = true;
  if(ok) stats.r++; else stats.f++;
  saveStats();
  render();
}

/* ---------------- Mode 2: Formen bilden ---------------- */
function newQuestion_formen(){
  const p = pool();
  if(!p.length){ state.current=null; render(); return; }
  const n = randPick(p);
  const num = pickNumerus(n);
  const cs = activeCasesFor(n);
  const kasus = randPick(cs);
  const forms = paradigm(n);
  const correct = forms[num+"_"+kasus];

  // Distraktoren: andere Formen desselben Worts (unter aktiven Filtern), sonst von anderen Wörtern derselben Deklination
  let candidates = [];
  ["sg","pl"].forEach(nu=>{
    if(n.pt && nu==="sg") return;
    cs.forEach(ka=>{ const f = forms[nu+"_"+ka]; if(f!==correct) candidates.push(f); });
  });
  candidates = [...new Set(candidates)];
  while(candidates.length < 3){
    const other = randPick(pool().filter(x=>x.d===n.d));
    if(!other) break;
    const of = paradigm(other);
    const rnd = of[randPick(["sg","pl"])+"_"+randPick(["nom","gen","akk","abl"])];
    if(rnd && rnd!==correct && !candidates.includes(rnd)) candidates.push(rnd);
  }
  candidates = candidates.slice(0,3);
  const options = [...candidates, correct].sort(()=>Math.random()-0.5);

  state.current = {n, num, kasus, correct, options};
  state.answered = false;
  render();
}

function selectOption(idx){
  if(state.answered) return;
  const c = state.current;
  state.selectedIdx = idx;
  state.answered = true;
  const ok = c.options[idx] === c.correct;
  if(ok) stats.r++; else stats.f++;
  saveStats();
  render();
}

/* ---------------- Mode 3: Kasusfragen ---------------- */
function newQuestion_kasusfragen(){
  const bank = KASUS_QUESTIONS.filter(q=>state.cas.has(q.kasus));
  if(!bank.length){ state.current=null; render(); return; }
  const q = randPick(bank);
  const correct = CASUS_LABEL[q.kasus];
  const options = [...state.cas].map(k=>CASUS_LABEL[k]).sort(()=>Math.random()-0.5);
  state.current = {q, correct, options};
  state.answered = false;
  render();
}

/* ---------------- Mode 4: Genitiv-Sprint ---------------- */
function newQuestion_genitiv(){
  const p = pool().filter(n=>!n.pt);
  if(!p.length){ state.current=null; render(); return; }
  const n = randPick(p);
  const forms = paradigm(n);
  const correct = forms.sg_gen;
  let candidates = [forms.sg_nom, forms.sg_dat, forms.sg_akk, forms.sg_abl].filter(f=>f!==correct);
  candidates = [...new Set(candidates)];
  while(candidates.length < 3){
    const other = randPick(p.filter(x=>x.d===n.d && x!==n));
    if(!other) break;
    const og = paradigm(other).sg_gen;
    if(og!==correct && !candidates.includes(og)) candidates.push(og);
  }
  candidates = candidates.slice(0,3);
  const options = [...candidates, correct].sort(()=>Math.random()-0.5);
  state.current = {n, correct, options};
  state.answered = false;
  render();
}

/* ---------------- Mode 5: Vokabeltrainer ---------------- */
function newQuestion_vokabeln(){
  const p = VOCAB.filter(n=>state.lekt.has(n.k));
  if(!p.length){ state.current=null; render(); return; }
  const n = randPick(p);
  const direction = Math.random()<0.5 ? "lat2de" : "de2lat";
  const correct = direction==="lat2de" ? n.de : n.l;
  const field = direction==="lat2de" ? "de" : "l";
  let candidates = [...new Set(p.filter(x=>x!==n).map(x=>x[field]))].sort(()=>Math.random()-0.5).slice(0,3);
  const options = [...candidates, correct].sort(()=>Math.random()-0.5);
  state.current = {n, direction, correct, options};
  state.answered = false;
  render();
}

/* ---------------- Mode 6: Lückensatz ---------------- */
function newQuestion_luecken(){
  const p = LUECKEN.filter(item=>{
    const n = VOCAB.find(x=>x.l===item.word);
    return n && state.lekt.has(n.k) && state.dekl.has(n.d) && state.cas.has(item.kasus);
  });
  if(!p.length){ state.current=null; render(); return; }
  const item = randPick(p);
  const n = VOCAB.find(x=>x.l===item.word);
  const forms = paradigm(n);
  const correct = forms[item.num+"_"+item.kasus];
  let candidates = [];
  ["sg","pl"].forEach(nu=>{
    ["nom","gen","dat","akk","abl"].forEach(ka=>{
      const f = forms[nu+"_"+ka]; if(f!==correct) candidates.push(f);
    });
  });
  candidates = [...new Set(candidates)].sort(()=>Math.random()-0.5).slice(0,3);
  const options = [...candidates, correct].sort(()=>Math.random()-0.5);
  state.current = {item, n, correct, options};
  state.answered = false;
  render();
}

function newQuestion(){
  if(state.tab==="bestimmen") newQuestion_bestimmen();
  else if(state.tab==="formen") newQuestion_formen();
  else if(state.tab==="kasusfragen") newQuestion_kasusfragen();
  else if(state.tab==="genitiv") newQuestion_genitiv();
  else if(state.tab==="vokabeln") newQuestion_vokabeln();
  else if(state.tab==="luecken") newQuestion_luecken();
  else render();
}

/* ---------------- Layover: vollständige Deklination ---------------- */
function openParadigm(){
  if(!state.answered || !state.current) return;
  const n = state.current.n;
  const f = paradigm(n);
  const info = DECL_INFO[declKey(n)];
  const order = ["nom","gen","dat","akk","abl"];
  const activeCases = order.filter(c=>state.cas.has(c));
  const rowLabels = {nom:"Nom.",gen:"Gen.",dat:"Dat.",akk:"Akk.",abl:"Abl."};
  const rows = activeCases.map(c=>`<tr><td>${rowLabels[c]}</td><td>${f["sg_"+c]}</td><td>${f["pl_"+c]}</td></tr>`).join("");
  const pt = n.pt ? `<div class="miniNote">Dieses Wort kommt nur im Plural vor – die Singularformen sind grammatisch gebildet, aber im echten Latein ungebräuchlich.</div>` : "";
  const filterNote = activeCases.length < 5 ? `<div class="miniNote">Zeigt nur die Kasus, die aktuell in ⚙︎ Einstellungen aktiviert sind.</div>` : "";
  document.getElementById("paraModalCard").innerHTML = `
    <button class="modalClose" onclick="closeParadigm()">✕</button>
    <div class="refHead" style="margin-top:0;">${n.l} <span style="color:var(--sub);font-weight:400;">— ${n.de}</span></div>
    <div class="miniNote" style="margin-bottom:10px;">${info.name}</div>
    <table class="refTable">
      <tr><th></th><th>Singular</th><th>Plural</th></tr>
      ${rows}
    </table>
    <div class="miniNote">${info.tip}</div>
    ${pt}
    ${filterNote}`;
  document.getElementById("paraModalWrap").classList.add("show");
}
function closeParadigm(){ document.getElementById("paraModalWrap").classList.remove("show"); }

/* ---------------- Render ---------------- */
function render(){
  const main = document.getElementById("main");
  if(state.tab==="tabellen"){ main.innerHTML = renderTabellen(); return; }

  if(!state.current){
    main.innerHTML = `<div class="card"><div class="empty">Keine Vokabeln für diese Filter ausgewählt.<br>Tippe oben rechts auf ⚙︎, um Lektionen oder Deklinationen zu aktivieren.</div></div>`;
    return;
  }

  if(state.tab==="bestimmen") main.innerHTML = renderBestimmen();
  else if(state.tab==="formen") main.innerHTML = renderFormen();
  else if(state.tab==="kasusfragen") main.innerHTML = renderKasusfragen();
  else if(state.tab==="genitiv") main.innerHTML = renderGenitiv();
  else if(state.tab==="vokabeln") main.innerHTML = renderVokabeln();
  else if(state.tab==="luecken") main.innerHTML = renderLuecken();
}

function renderBestimmen(){
  const c = state.current;
  const casOpts = [...state.cas].sort((a,b)=>["nom","gen","dat","akk","abl"].indexOf(a)-["nom","gen","dat","akk","abl"].indexOf(b));
  let kasusBtns = casOpts.map(k=>{
    let cls="opt"+(state.selKasus===k?" sel":"");
    return `<div class="${cls}" onclick="selectKasus('${k}')">${CASUS_LABEL[k]}</div>`;
  }).join("");
  let numBtns = ["sg","pl"].map(k=>{
    let cls="opt"+(state.selNum===k?" sel":"");
    return `<div class="${cls}" onclick="selectNum('${k}')">${NUM_LABEL[k]}</div>`;
  }).join("");
  let genBtns = ["m","f","n"].map(k=>{
    let cls="opt"+(state.selGen===k?" sel":"");
    if(state.answered){
      if(state.selGen===k) cls += (k===c.n.g)?" correct":" wrong";
    }
    return `<div class="${cls}" onclick="selectGen('${k}')">${GEN_LABEL[k]}</div>`;
  }).join("");
  const DEKL_SHORT = {a:"a-Dekl.", o:"o-Dekl.", kons:"kons-Dekl."};
  let deklBtns = ["a","o","kons"].map(k=>{
    let cls="opt"+(state.selDekl===k?" sel":"");
    if(state.answered){
      if(state.selDekl===k) cls += (k===c.n.d)?" correct":" wrong";
    }
    return `<div class="${cls}" onclick="selectDekl('${k}')">${DEKL_SHORT[k]}</div>`;
  }).join("");

  // Chips: bereits hinzugefügte Kasus/Numerus-Kombinationen
  const matchKeys = c.matches.map(m=>m.kasus+"_"+m.num);
  let chips = "";
  if(!state.answered){
    chips = state.selPairs.map((p,idx)=>
      `<span class="chip" style="background:#e5f0fe;color:var(--blue-d);font-weight:600;" onclick="removePair(${idx})">${CASUS_LABEL[p.kasus]} ${NUM_LABEL[p.num]} ✕</span>`
    ).join(" ");
  } else {
    chips = state.finalPairs.map(p=>{
      const ok = matchKeys.includes(p.kasus+"_"+p.num);
      return `<span class="chip" style="background:${ok?'var(--green-bg)':'var(--red-bg)'};color:${ok?'var(--green)':'var(--red)'};font-weight:600;">${CASUS_LABEL[p.kasus]} ${NUM_LABEL[p.num]} ${ok?'✓':'✕'}</span>`;
    }).join(" ");
  }

  let fb = "";
  if(state.answered){
    const genOk = state.selGen === c.n.g;
    const deklOk = state.askDekl ? (state.selDekl === c.n.d) : true;
    const ok = state.finalMissing.length===0 && state.finalExtra.length===0 && genOk && deklOk;
    const info = DECL_INFO[declKey(c.n)];
    const validList = c.matches.map(m=>`${CASUS_LABEL[m.kasus]} ${NUM_LABEL[m.num]}`).join(" oder ");
    const missingLine = state.finalMissing.length
      ? `<div style="margin-top:6px;">Nicht angegeben: ${state.finalMissing.map(m=>`${CASUS_LABEL[m.kasus]} ${NUM_LABEL[m.num]}`).join(", ")}</div>` : "";
    fb = `<div class="feedback ${ok?'ok':'bad'}">
      <b>${ok?"✓ Richtig!":"✗ Nicht ganz."}</b>
      "${c.form}" ist: ${validList}, ${GEN_LABEL[c.n.g]}, ${info.name}.
      ${missingLine}
      <div class="why">${info.tip}</div>
      ${extraInfoHtml(c.n, c.kasus, c.num)}
    </div>
    <button class="secondary" onclick="openParadigm()">🔎 Vollständige Deklination ansehen</button>`;
  }

  const canAdd = !state.answered && state.selKasus && state.selNum && !state.selPairs.some(p=>p.kasus===state.selKasus && p.num===state.selNum);
  const canSubmit = ((state.selPairs.length>0) || (state.selKasus && state.selNum)) && state.selGen && (!state.askDekl || state.selDekl);

  return `
  <div class="card">
    <div class="stats"><span class="chip">L${c.n.k}</span>${state.answered?`<span class="chip">${DECL_INFO[declKey(c.n)].name}</span>`:``}<span style="margin-left:auto;">✓ <b>${stats.r}</b> · ✗ <b>${stats.f}</b></span></div>
    <div class="prompt-label">Bestimme diese Form</div>
    <div class="latinWord">${c.form}</div>
    ${!state.answered?`<div class="miniNote" style="text-align:center;margin-bottom:10px;">Manche Formen sind mehrdeutig – füge bei Bedarf mehrere Kombinationen hinzu.</div>`:``}

    ${!state.answered?`
    <div class="grp"><div class="grp-label">Kasus</div><div class="btnrow">${kasusBtns}</div></div>
    <div class="grp"><div class="grp-label">Numerus</div><div class="btnrow">${numBtns}</div></div>
    <button class="secondary" ${canAdd?"":"disabled"} onclick="addPair()">+ Kombination hinzufügen</button>
    `:``}
    ${chips?`<div class="btnrow" style="margin:10px 0;">${chips}</div>`:``}

    <div class="grp" style="margin-top:14px;"><div class="grp-label">Genus</div><div class="btnrow">${genBtns}</div></div>
    ${state.askDekl?`<div class="grp"><div class="grp-label">Deklination</div><div class="btnrow">${deklBtns}</div></div>`:``}

    ${fb}
    ${state.answered
      ? `<button class="primary" onclick="newQuestion()">Nächste Form →</button>`
      : `<button class="primary" ${canSubmit?"":"disabled"} onclick="submitBestimmen()">Prüfen</button>`}
  </div>`;
}

function renderFormen(){
  const c = state.current;
  let opts = c.options.map((o,i)=>{
    let cls="mcOpt";
    if(state.answered){
      if(o===c.correct) cls+=" correct";
      else if(i===state.selectedIdx) cls+=" wrong";
    }
    return `<div class="${cls}" onclick="selectOption(${i})">${o}</div>`;
  }).join("");

  let fb = "";
  if(state.answered){
    const ok = c.options[state.selectedIdx]===c.correct;
    const info = DECL_INFO[declKey(c.n)];
    fb = `<div class="feedback ${ok?'ok':'bad'}">
      <b>${ok?"✓ Richtig!":"✗ Nicht ganz."}</b>
      Die richtige Form ist "${c.correct}".
      <div class="why">${info.name}: ${info.tip}</div>
      ${extraInfoHtml(c.n, c.kasus, c.num)}
    </div>
    <button class="secondary" onclick="openParadigm()">🔎 Vollständige Deklination ansehen</button>`;
  }

  return `
  <div class="card">
    <div class="stats"><span class="chip">L${c.n.k}</span><span class="chip">${DECL_INFO[declKey(c.n)].name}</span><span style="margin-left:auto;">✓ <b>${stats.r}</b> · ✗ <b>${stats.f}</b></span></div>
    <div class="prompt-label">Bilde die richtige Form</div>
    <div class="latinWord" style="font-size:26px;">${c.n.l}</div>
    <div class="meaning">${c.n.de}</div>
    <div class="askrow"><span class="askchip">${CASUS_LABEL[c.kasus]}</span><span class="askchip">${NUM_LABEL[c.num]}</span></div>

    ${opts}
    ${fb}
    ${state.answered ? `<button class="primary" onclick="newQuestion()">Nächste Form →</button>` : ``}
  </div>`;
}

