{l:"līberī",s:"līber",g:"m",d:"o",k:2,de:"Kinder",dg:"n",w:0,dp:"Kinder",pt:1},
{l:"vir",s:"vir",g:"m",d:"o",k:2,de:"Mann",dg:"m",w:0,dp:"Männer"},
{l:"ātrium",s:"ātri",g:"n",d:"o",k:2,de:"Atrium",dg:"n",w:0,dp:"Atrien"},
{l:"ōtium",s:"ōti",g:"n",d:"o",k:2,de:"Freizeit",dg:"f",w:0,dp:"Freizeiten"},

{l:"equus",s:"equ",g:"m",d:"o",k:3,de:"Pferd",dg:"n",w:0,dp:"Pferde"},
